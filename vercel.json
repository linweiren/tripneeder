{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/generate-trip.ts": {
      "maxDuration": 300
    },
    "api/generate-trip-details.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
