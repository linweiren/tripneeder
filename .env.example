# Tripneeder local development
#
# Variables prefixed with VITE_ are exposed to the browser bundle.
# Never put OpenAI keys or Supabase service role keys in VITE_ variables.

# Public Supabase client config. Safe to expose; access is protected by Supabase RLS.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side Supabase config for /api/generate-trip.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side OpenAI config for /api/generate-trip.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Server-side Google API config for Geocoding and Places.
GOOGLE_PLACES_API_KEY=your-google-api-key

# Local-only points manager config.
# Keep this out of Vercel unless a future server-side admin backend explicitly needs it.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
